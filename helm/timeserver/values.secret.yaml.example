# Example secrets values file.
#
# Copy this file to values.secret.yaml, fill in real values, and pass it
# at deploy time. The actual file is gitignored — never commit real secrets.
#
#   helm upgrade timeserver ./helm/timeserver -f values.secret.yaml

secret:
  create: true
  data:
    OTEL_EXPORTER_OTLP_ENDPOINT: "http://your-collector:4318"
    # Add further secret keys here as the app grows
